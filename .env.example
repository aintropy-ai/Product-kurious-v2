# ──────────────────────────────────────────────────────────────────────────────
# Local development environment template
# Copy to .env and fill in real values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Kurious Backend API ────────────────────────────────────────────────────────
VITE_BACKEND_API_URL=https://kurious-backend-api.centralus.cloudapp.azure.com
VITE_BACKEND_API_KEY=your_kurious_api_key_here
VITE_BACKEND_COMPANY_ID=your_company_id_here

# ── OpenRouter API (for frontier LLM comparison) ────────────────────────────────
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional: Anthropic API Key (Claude models) ────────────────────────────────
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
